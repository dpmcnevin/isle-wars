{
	"name": "isle-wars",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"log:path": "node -e \"console.log(require('os').tmpdir() + '/isle-wars-events.jsonl')\"",
		"log:tail": "node -e \"require('child_process').spawn('tail', ['-f', require('os').tmpdir() + '/isle-wars-events.jsonl'], {stdio:'inherit'})\"",
		"log:clear": "node -e \"require('fs').rmSync(require('os').tmpdir() + '/isle-wars-events.jsonl', {force:true})\""
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/d3-delaunay": "^6.0.4",
		"@types/node": "^26.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"d3-delaunay": "^6.0.4",
		"polygon-clipping": "^0.15.7"
	}
}
